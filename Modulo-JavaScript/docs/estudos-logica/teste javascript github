// Em vez de apenas um objeto plano, vamos criar uma estrutura que entenda a hierarquia do seu curso.
// Para que a porcentagem seja exata, a função deve calcular:
// O progresso dentro de cada módulo.
// O peso desse módulo no gráfico geral.

function calculateKnowledge() {
  let totalGlobalProgress = 0;

  const stats = Object.keys(courseMap).map(key => {
    const module = courseMap[key];
    const progress = (module.completed.length / module.topics.length) * 100;
    
    // Contribuição deste módulo para o gráfico de 0 a 100
    totalGlobalProgress += (progress * module.weight);

    return {
      label: module.language,
      value: progress.toFixed(2)
    };
  });

  return { stats, totalGlobalProgress };
}


// O Script Node.js (scanner.js): Este script vai percorrer seus módulos e verificar a presença do arquivo gatilho.

const fs = require('fs');

const path = require('path');



// Configuração dos módulos que você quer mapear

const modules = [

  { name: 'Modulo-JavaScript', weight: 0.3 },

  { name: 'Modulo-TypeScript', weight: 0.4 },

  { name: 'Modulo-Angular', weight: 0.3 }

];



function scanProgress() {

  const report = {};



  modules.forEach(mod => {

    const modPath = path.join(__dirname, mod.name);

    

    if (fs.existsSync(modPath)) {

      // Lê todas as subpastas (os tópicos/aulas)

      const topics = fs.readdirSync(modPath).filter(file => 

        fs.statSync(path.join(modPath, file)).isDirectory()

      );



      let completedCount = 0;



      topics.forEach(topic => {

        const markerPath = path.join(modPath, topic, 'exercicio-concluido.md');

        if (fs.existsSync(markerPath)) {

          completedCount++;

        }

      });



      const percentage = topics.length > 0 ? (completedCount / topics.length) * 100 : 0;

      

      report[mod.name] = {

        name: mod.name.replace('Modulo-', ''),

        percentage: parseFloat(percentage.toFixed(2)),

        totalTopics: topics.length,

        completedTopics: completedCount

      };

    }

  });



  // Salva o resultado em um JSON para o seu gráfico ler

  fs.writeFileSync('progress-data.json', JSON.stringify(report, null, 2));

  console.log('✅ Progresso mapeado com sucesso em progress-data.json');

}



scanProgress();

